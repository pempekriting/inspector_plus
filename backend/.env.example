# InspectorPlus Backend - Environment Variables
# Copy this file to .env and fill in your values

# --- Device Selection ---
# Force a specific Android device serial (leave empty for auto-detect)
ANDROID_SERIAL=

# --- Security ---
# Comma-separated CORS origins (no spaces)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,app://localhost,tauri://localhost

# --- Logging ---
LOG_LEVEL=INFO

# --- App Version (for Docker deployments) ---
APP_VERSION=0.0.1
