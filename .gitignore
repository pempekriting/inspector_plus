# ============================================
# InspectorPlus - Root .gitignore
# ============================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
*.egg
*.egg-info/

# Environment (never commit secrets)
.env
.env.local
.env.*.local
.env.example

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log
npm-debug.log*
uv.lock

# Testing
coverage/
.pytest_cache/
.coverage
htmlcov/
.tox/

# Python (backend)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
env/

# Tauri (desktop app)
src-tauri/target/
src-tauri/.cargo/

# Misc
Thumbs.db
*.iml
*.suo